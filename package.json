{
  "name": "spades",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:socket": "tsx watch socket-server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:socket\"",
    "build": "node scripts/build-clean.js",
    "build:socket": "esbuild socket-server.ts --bundle --platform=node --outfile=dist/socket-server.js --external:bufferutil --external:utf-8-validate",
    "start": "next start",
    "start:socket": "node dist/socket-server.js",
    "lint": "eslint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.8.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@types/three": "^0.181.0",
    "framer-motion": "^12.23.24",
    "next": "16.0.4",
    "prisma": "^6.8.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.181.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.8.32",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
